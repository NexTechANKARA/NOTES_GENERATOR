@{
    ViewData["Title"] = "SmartNotes AI — Engineering Notes Generator";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero -->
<section class="landing-hero">
    <div class="hero-tag">✦ AI-Powered · Engineering-Grade Notes</div>
    <h1 class="hero-title">Notes That <em>Compete</em><br>With Textbooks</h1>
    <p class="hero-sub">
        SmartNotes generates deep, structured engineering notes — with in-depth explanations, worked examples,
        technical diagrams, and exam-quality questions. Not generic AI output. Textbook standard.
    </p>
    <div class="hero-actions">
        <a class="btn-primary-lg" asp-controller="Account" asp-action="Register">Start for Free ⚡</a>
        <a class="btn-ghost-lg" asp-controller="Account" asp-action="Login">I have an account</a>
    </div>
</section>

<!-- Problem vs Solution -->
<section class="compare-section">
    <div class="compare-grid">
        <div class="compare-card bad">
            <div class="compare-icon">❌</div>
            <h3>Generic AI Notes</h3>
            <ul>
                <li>Surface-level definitions only</li>
                <li>No real engineering examples</li>
                <li>No diagrams or visuals</li>
                <li>No exam-focused questions</li>
                <li>Reads like a Wikipedia summary</li>
            </ul>
        </div>
        <div class="compare-divider">VS</div>
        <div class="compare-card good">
            <div class="compare-icon">✅</div>
            <h3>SmartNotes AI</h3>
            <ul>
                <li>Deep theory with underlying principles</li>
                <li>Worked examples with real numbers</li>
                <li>ASCII diagrams with proper labels</li>
                <li>University-exam style questions</li>
                <li>Reads like a professor wrote it</li>
            </ul>
        </div>
    </div>
</section>

<!-- How it works -->
<section class="how-section">
    <h2 class="section-title">How It Works</h2>
    <div class="steps-grid">
        <div class="step-card">
            <div class="step-num">01</div>
            <h4>Enter Topic + Subject</h4>
            <p>Type any engineering topic — Data Structures, Thermodynamics, Control Systems, DBMS, anything.</p>
        </div>
        <div class="step-card">
            <div class="step-num">02</div>
            <h4>AI Decomposes & Researches</h4>
            <p>SmartNotes breaks the topic into subtopics, then researches each one in depth using Claude AI.</p>
        </div>
        <div class="step-card">
            <div class="step-num">03</div>
            <h4>4-Section Output</h4>
            <p>Get detailed Notes, Quick Summary, Practice Questions, and Technical Diagrams — all at once.</p>
        </div>
        <div class="step-card">
            <div class="step-num">04</div>
            <h4>Save & Revisit</h4>
            <p>Save notes to your account, access them anytime, build your personal engineering knowledge base.</p>
        </div>
    </div>
</section>

<!-- Stats -->
<section class="stats-section">
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-num">4x</div>
            <div class="stat-label">More depth than standard AI notes</div>
        </div>
        <div class="stat-card">
            <div class="stat-num">2-stage</div>
            <div class="stat-label">AI pipeline for quality output</div>
        </div>
        <div class="stat-card">
            <div class="stat-num">4</div>
            <div class="stat-label">Sections per topic generated</div>
        </div>
        <div class="stat-card">
            <div class="stat-num">∞</div>
            <div class="stat-label">Topics you can save and revisit</div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="cta-section">
    <h2>Ready to Study Smarter?</h2>
    <p>Create your free account and generate your first set of engineering notes in seconds.</p>
    <a class="btn-primary-lg" asp-controller="Account" asp-action="Register">Get Started — It's Free ⚡</a>
</section>
