<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartNotes</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script type="module">
        import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
        mermaid.initialize({
            startOnLoad: true,
            theme: 'dark',
            themeVariables: {
                primaryColor: '#1e3a5f',
                primaryTextColor: '#e2e8f0',
                primaryBorderColor: '#3b82f6',
                lineColor: '#60a5fa',
                secondaryColor: '#111827',
                tertiaryColor: '#161f30',
                background: '#080c14',
                mainBkg: '#111827',
                nodeBorder: '#3b82f6',
                clusterBkg: '#161f30',
                titleColor: '#e2e8f0',
                edgeLabelBackground: '#111827',
                fontFamily: 'DM Sans, sans-serif'
            }
        });
        window.mermaid = mermaid;
    </script>
</head>
<body>

<div class="bg-grid"></div>
<div class="bg-glow glow-1"></div>
<div class="bg-glow glow-2"></div>

<header class="header">
    <div class="header-inner">
        <a class="logo" asp-controller="Home" asp-action="Index">
            <span class="logo-icon">⚡</span>
            <span class="logo-text">SmartNotes <span class="logo-badge">AI</span></span>
        </a>
        <nav class="header-nav">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="nav-link" asp-controller="Notes" asp-action="Generate">Generate</a>
                <a class="nav-link" asp-controller="Notes" asp-action="MyNotes">My Notes</a>
                <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="nav-link nav-btn">Logout</button>
                </form>
            }
            else
            {
                <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                <a class="nav-link nav-cta" asp-controller="Account" asp-action="Register">Get Started</a>
            }
        </nav>
    </div>
</header>

<main class="main-wrap">
    @RenderBody()
</main>

<footer class="footer">
    <p>SmartNotes AI · Powered by Claude (Anthropic) · Built for Engineering Students</p>
</footer>

<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
